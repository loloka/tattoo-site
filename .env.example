# =====================================================================
#  НАСТРОЙКИ САЙТА  (шаблон)
#
#  Как пользоваться:
#  1) Скопируй этот файл в файл с именем  .env   (без .example):
#        Windows:  copy .env.example .env
#        Mac/Linux: cp .env.example .env
#  2) Поменяй значения ниже на свои (или оставь как есть — тут уже вписаны
#     тексты по умолчанию, ровно те, что сейчас на сайте).
#  3) Применить изменения:  docker compose up -d
#
#  ── ПРАВИЛА ФОРМАТА (важно) ─────────────────────────────────────────
#  • Одна настройка = одна строка вида  ИМЯ=значение
#  • Кавычки НЕ нужны. Пиши текст прямо после «=».
#        Пример:  SITE_SUBTITLE=Tattoo Artworks
#  • Значение — ВСЕГДА в одну строку. Настоящий перенос строки тут не
#    работает. Чтобы сделать перенос/новый абзац внутри текста (нужно
#    только в био) — пиши две буквы  \n  там, где хочешь перенос.
#        Пример:  SITE_BIO=Первая строка.\nВторая строка.
#  • Двуязычные подписи пишутся через « / » в формате  Текст1 / Text2
#        Пример:  FORM_LABEL_NAME=Имя / Name *
#  • Пустое значение (ИМЯ=) → сайт подставит текст по умолчанию из кода.
#    Здесь всё уже заполнено, так что можно просто править готовое.
#  • Символы вроде →  ✕  ü  ß  писать можно как есть (файл в UTF-8).
#  • НЕ добавляй комментарий (#) в конце строки со значением — коммент
#    только на отдельной строке, иначе он попадёт в текст.
# =====================================================================


# ─────────────────────────────────────────────────────────────────────
#  БАЗА ДАННЫХ  (для локального Docker менять НЕ нужно)
# ─────────────────────────────────────────────────────────────────────
DB_DATABASE=art_site
DB_USER=art_user
DB_PASSWORD=art_pass
DB_ROOT_PASSWORD=root_pass


# ─────────────────────────────────────────────────────────────────────
#  ИМЯ И ТЕЛЕГРАМ ВЛАДЕЛИЦЫ
# ─────────────────────────────────────────────────────────────────────
# Большой заголовок на главной = ИМЯ (слева) + ФАМИЛИЯ (справа).
SITE_OWNER_FIRST=Marie
SITE_OWNER_LAST=Holzer
# Как телеграм показывается в шапке и футере (просто текст):
SITE_TELEGRAM=@Uktpxandy
# Куда ведёт ссылка на телеграм (полный адрес):
SITE_TELEGRAM_URL=https://t.me/Uktpxandy


# ─────────────────────────────────────────────────────────────────────
#  ПОДЗАГОЛОВОК ПОД ИМЕНЕМ
# ─────────────────────────────────────────────────────────────────────
# Жирная надпись под именем:
SITE_SUBTITLE=Tattoo Artworks
# Мелкая серая строка НАД ней:
SITE_SUBTITLE_EYEBROW=Personal Art Collection


# ─────────────────────────────────────────────────────────────────────
#  МЕНЮ В ШАПКЕ
# ─────────────────────────────────────────────────────────────────────
SITE_NAV_HOME=Гл. страница
SITE_NAV_GALLERY=Галерея
SITE_NAV_CONTACT=Контакты


# ─────────────────────────────────────────────────────────────────────
#  БИО СЛЕВА  ("About me" / "Über mich")
#  Абзацы/переносы внутри текста — через \n  (см. правила формата вверху).
# ─────────────────────────────────────────────────────────────────────
# Заголовок блока (англ. и нем.):
SITE_BIO_LABEL=About me
SITE_BIO_LABEL_DE=Über mich
# Сам текст био (англ.):
SITE_BIO=Born in Siberia, currently based in Ufa.\nProfessional tattoo artist since 2011.\nSpecializing in vibrant color tattoos.\nExpertise in complex cover-ups.\nProfessional background in fine arts.\nOver 1,000+ satisfied clients.
# Сам текст био (нем.):
SITE_BIO_DE=Geboren in Sibirien, derzeit tätig in Ufa.\nProfessionelle Tätowiererin seit 2011.\nSpezialisiert auf farbige Tattoos.\nErfahren in komplexen Cover-ups.\nProfessionelle Kunstausbildung.\nÜber 1.000+ zufriedene Kunden.


# ─────────────────────────────────────────────────────────────────────
#  КОРОТКАЯ ПОДПИСЬ КОНТАКТОВ РЯДОМ С БИО  ("Contact me" / "Kontakt")
# ─────────────────────────────────────────────────────────────────────
SITE_CONTACT_LABEL=Contact me: E mail/Telegram/Fill out the form below
SITE_CONTACT_LABEL_DE=Kontakt: E Mail/Telegram/Das Formular unten ausfüllen


# ─────────────────────────────────────────────────────────────────────
#  ГАЛЕРЕЯ
# ─────────────────────────────────────────────────────────────────────
# Мелкая строка над заголовком галереи (англ. / нем.):
GALLERY_EYEBROW=Selected works: Section 01
GALLERY_EYEBROW_DE=Ausgewählte Arbeiten: Abschnitt 01
# Сам заголовок галереи (показывается как "Gallery / Galerie"):
GALLERY_TITLE=Gallery
GALLERY_TITLE_DE=Galerie
# Что написать, если ни одной работы ещё не добавлено:
GALLERY_EMPTY=Works will appear here soon.
GALLERY_EMPTY_DE=Werke erscheinen hier bald.


# ─────────────────────────────────────────────────────────────────────
#  ФОРМА "СВЯЗАТЬСЯ" — ЗАГОЛОВОК И ПОЯСНЕНИЕ
# ─────────────────────────────────────────────────────────────────────
# Крупный заголовок над формой (показывается как "Get in touch / Kontakt"):
CONTACT_FORM_TITLE=Get in touch
CONTACT_FORM_TITLE_DE=Kontakt
# Пояснение под заголовком:
CONTACT_FORM_INTRO=Fill out the form — the message will be sent directly to Telegram
CONTACT_FORM_INTRO_DE=Das Formular unten ausfüllen — die Nachricht wird direkt an Telegram gesendet


# ─────────────────────────────────────────────────────────────────────
#  ФОРМА "СВЯЗАТЬСЯ" — ПОЛЯ И КНОПКА
#  Подписи двуязычные, формат  "Русский / Deutsch". Звёздочка * = обязательное поле.
# ─────────────────────────────────────────────────────────────────────
# Подпись поля "имя":
FORM_LABEL_NAME=Имя / Name *
# Подпись выпадающего списка "тема обращения":
FORM_LABEL_TOPIC=Тема обращения / Betreff *
# Первый (пустой) пункт списка — приглашение выбрать:
FORM_TOPIC_PLACEHOLDER=Выбрать тему / Betreff auswählen
# Варианты в списке "тема обращения". Оставишь вариант пустым — он не покажется.
FORM_TOPIC_1=Хочу предложить работу / Ich möchte eine Arbeit anbieten
FORM_TOPIC_2=Вопрос по работе / покупке / Frage zur Arbeit / zum Kauf
FORM_TOPIC_3=Сотрудничество / Zusammenarbeit
FORM_TOPIC_4=Другое / Sonstiges
# Подпись поля "комментарий":
FORM_LABEL_COMMENT=Комментарий (не обязательно) / Kommentar (optional)
# Подпись поля "контакт":
FORM_LABEL_CONTACT=Телеграм или телефон / Telegram oder Telefonnummer *
# Строка про согласие на обработку данных (под полями), рус. и нем.:
FORM_CONSENT=Нажимая на кнопку, вы соглашаетесь на обработку данных.
FORM_CONSENT_DE=Mit dem Klick auf die Schaltfläche stimmen Sie der Datenverarbeitung zu.
# Надпись на кнопке отправки, рус. и нем.:
FORM_SUBMIT=Отправить →
FORM_SUBMIT_DE=Absenden →


# ─────────────────────────────────────────────────────────────────────
#  ЛАЙТБОКС  (подпись "закрыть" при просмотре работы во весь экран)
# ─────────────────────────────────────────────────────────────────────
LIGHTBOX_CLOSE=Закрыть / Schließen ✕


# ─────────────────────────────────────────────────────────────────────
#  ФУТЕР — строка про телеграм-канал со скетчами
# ─────────────────────────────────────────────────────────────────────
SITE_TG_CHANNEL_NOTE=Telegram channel where I share my everyday sketches
SITE_TG_CHANNEL_NOTE_DE=Telegram-Kanal, bei dem ich meine alltäglichen Skizzen teile


# ─────────────────────────────────────────────────────────────────────
#  TELEGRAM-БОТ для формы "связаться"
#  Как получить оба значения — подробно в README (раздел про бота).
#  Коротко: @BotFather → /newbot → токен; затем напиши боту, открой
#  https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьми "chat":{"id":...}.
#  Можно оставить пустыми — форма будет работать, но заявки никуда не уйдут.
# ─────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
