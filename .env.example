# Настройки для локального демо-запуска через Docker.
# Меняй смело — это не боевой сервер, а просто контейнер на твоём компьютере.
#
# ВАЖНО про пустые значения ниже: если строка вида ИМЯ= оставлена пустой —
# сайт САМ подставит текст по умолчанию из макета mashasite.psd (англ. + нем.).
# Если хочешь свой текст — впиши его после "=". Значение должно быть в одну
# строку (перенос строки внутри .env не работает); чтобы сделать перенос
# строки/абзац внутри текста (например, в био) — пиши буквально \n, на
# странице это превратится в настоящий перенос строки.
#
# После любого изменения тут — либо `docker compose up -d` (без --build,
# просто пересоздаст контейнер с новыми значениями), либо `start.bat`.

# --- База данных ---
DB_DATABASE=art_site
DB_USER=art_user
DB_PASSWORD=art_pass
DB_ROOT_PASSWORD=root_pass

# --- Имя/телеграм владелицы сайта ---
SITE_OWNER_FIRST=Mary
SITE_OWNER_LAST=Holzer
SITE_TELEGRAM=@Uktpxandy
SITE_TELEGRAM_URL=https://t.me/Uktpxandy

# --- Подзаголовок под именем (жирный + мелкая серая надпись над ним) ---
SITE_SUBTITLE=Tattoo Artworks
SITE_SUBTITLE_EYEBROW=

# --- Пункты меню в шапке ---
SITE_NAV_HOME=
SITE_NAV_GALLERY=
SITE_NAV_CONTACT=

# --- Био слева ("About me" / "Über mich") ---
SITE_BIO_LABEL=
SITE_BIO_LABEL_DE=
SITE_BIO=
SITE_BIO_DE=

# --- Короткая подпись контактов рядом с био ("Contact me" / "Kontakt") ---
SITE_CONTACT_LABEL=
SITE_CONTACT_LABEL_DE=

# --- Галерея: эйбрау над заголовком, сам заголовок, текст при пустой галерее ---
GALLERY_EYEBROW=
GALLERY_EYEBROW_DE=
GALLERY_TITLE=
GALLERY_TITLE_DE=
GALLERY_EMPTY=
GALLERY_EMPTY_DE=

# --- Форма "связаться": заголовок и пояснение над полями ---
CONTACT_FORM_TITLE=
CONTACT_FORM_TITLE_DE=
CONTACT_FORM_INTRO=
CONTACT_FORM_INTRO_DE=

# --- Футер: строка про телеграм-канал со скетчами ---
SITE_TG_CHANNEL_NOTE=
SITE_TG_CHANNEL_NOTE_DE=

# --- Telegram-бот для формы "связаться" (можно оставить пустым для теста) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
